# ---- Supabase ----
# Project Settings → API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-only, NEVER exposed to the client.
# Same page, labeled "service_role" (click "Reveal").
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Support agent login ----
# The single support agent's credentials for /support/login
SUPPORT_AGENT_USERNAME=agent
SUPPORT_AGENT_PASSWORD=change-me

# Random string used to sign the agent's session cookie.
# Generate one with: openssl rand -hex 32
SUPPORT_SESSION_SECRET=replace-with-a-long-random-string

# ---- Cron ----
# Secret the purge-conversations cron endpoint checks for.
# Generate one with: openssl rand -hex 32
CRON_SECRET=replace-with-a-long-random-string
